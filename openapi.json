{
    "openapi": "3.0.0",
    "paths": {
        "/api/status": {
            "get": {
                "operationId": "status",
                "parameters": [],
                "responses": {
                    "200": {
                        "description": "Service status",
                        "content": {
                            "application/json": {
                                "example": {
                                    "status": "ok",
                                    "database": "ok"
                                }
                            }
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "Health check",
                "tags": [
                    "Status"
                ]
            }
        },
        "/api/channels": {
            "get": {
                "operationId": "getChannels",
                "parameters": [
                    {
                        "name": "order",
                        "required": false,
                        "in": "query",
                        "description": "Sort direction",
                        "schema": {
                            "enum": [
                                "desc",
                                "asc"
                            ],
                            "type": "string"
                        }
                    },
                    {
                        "name": "sort",
                        "required": false,
                        "in": "query",
                        "description": "Field to sort by",
                        "schema": {
                            "enum": [
                                "displayName",
                                "xmlId"
                            ],
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Items per page (max 100, default 20)",
                        "schema": {
                            "example": 20,
                            "type": "number"
                        }
                    },
                    {
                        "name": "page",
                        "required": false,
                        "in": "query",
                        "description": "Page number (min 1)",
                        "schema": {
                            "example": 1,
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of channels"
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "List channels",
                "tags": [
                    "Channels"
                ]
            }
        },
        "/api/channels/search": {
            "get": {
                "operationId": "searchChannels",
                "parameters": [
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Items per page (max 100, default 20)",
                        "schema": {
                            "example": 20,
                            "type": "number"
                        }
                    },
                    {
                        "name": "page",
                        "required": false,
                        "in": "query",
                        "description": "Page number (min 1)",
                        "schema": {
                            "example": 1,
                            "type": "number"
                        }
                    },
                    {
                        "name": "q",
                        "required": true,
                        "in": "query",
                        "description": "Search term",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated matching channels"
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "Search channels by name",
                "tags": [
                    "Channels"
                ]
            }
        },
        "/api/channels/tnt": {
            "get": {
                "operationId": "getTntChannels",
                "parameters": [],
                "responses": {
                    "200": {
                        "description": "TNT channels in order",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Channel"
                                    }
                                }
                            }
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "List TNT free channels in broadcast order",
                "tags": [
                    "Channels"
                ]
            }
        },
        "/api/channel/{id}": {
            "get": {
                "operationId": "getChannelDetails",
                "parameters": [
                    {
                        "name": "id",
                        "required": true,
                        "in": "path",
                        "description": "Channel UUID or xmlId",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "day",
                        "required": false,
                        "in": "query",
                        "description": "DD/MM/YYYY (Europe/Paris)",
                        "schema": {
                            "example": "20/05/2026",
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Channel with current and daily programs"
                    },
                    "404": {
                        "description": "Channel not found"
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "Get a channel with its current and daily programs",
                "tags": [
                    "Channels"
                ]
            }
        },
        "/api/program/{id}": {
            "get": {
                "description": "Lookup a program by its UUID.",
                "operationId": "getProgram",
                "parameters": [
                    {
                        "name": "id",
                        "required": true,
                        "in": "path",
                        "description": "Program UUID",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Program details"
                    },
                    "404": {
                        "description": "Program not found"
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "Get a program by id",
                "tags": [
                    "Programs"
                ]
            }
        },
        "/api/programs/now": {
            "get": {
                "description": "Returns a paginated list of programs airing now.",
                "operationId": "getCurrentPrograms",
                "parameters": [
                    {
                        "name": "order",
                        "required": false,
                        "in": "query",
                        "description": "Sort direction",
                        "schema": {
                            "enum": [
                                "desc",
                                "asc"
                            ],
                            "type": "string"
                        }
                    },
                    {
                        "name": "sort",
                        "required": false,
                        "in": "query",
                        "description": "Field to sort by",
                        "schema": {
                            "enum": [
                                "startAt",
                                "title"
                            ],
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Items per page (max 100, default 20)",
                        "schema": {
                            "example": 20,
                            "type": "number"
                        }
                    },
                    {
                        "name": "page",
                        "required": false,
                        "in": "query",
                        "description": "Page number (min 1)",
                        "schema": {
                            "example": 1,
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of current programs"
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "List currently airing programs",
                "tags": [
                    "Programs"
                ]
            }
        },
        "/api/programs/{day}": {
            "get": {
                "description": "Returns a paginated list of programs for the specified day.",
                "operationId": "getProgramsByDay",
                "parameters": [
                    {
                        "name": "day",
                        "required": true,
                        "in": "path",
                        "description": "Date in YYYY-MM-DD format",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Items per page (max 100, default 20)",
                        "schema": {
                            "example": 20,
                            "type": "number"
                        }
                    },
                    {
                        "name": "page",
                        "required": false,
                        "in": "query",
                        "description": "Page number (min 1)",
                        "schema": {
                            "example": 1,
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of programs for the day"
                    },
                    "400": {
                        "description": "Invalid date format"
                    },
                    "429": {
                        "description": "Rate limit exceeded"
                    }
                },
                "summary": "List programs for a specific day",
                "tags": [
                    "Programs"
                ]
            }
        },
        "/api/tmdb/init": {
            "get": {
                "operationId": "handleNewPrograms",
                "parameters": [],
                "responses": {
                    "200": {
                        "description": "Initialization triggered"
                    }
                },
                "summary": "Initialize TMDB details for all programs",
                "tags": [
                    "TMDB"
                ]
            }
        },
        "/api/tmdb/sync": {
            "get": {
                "operationId": "syncProgramScores",
                "parameters": [
                    {
                        "name": "title",
                        "required": false,
                        "in": "query",
                        "description": "Filter by program title",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sync completed"
                    }
                },
                "summary": "Sync TMDB scores for current programs",
                "tags": [
                    "TMDB"
                ]
            }
        },
        "/api/searxng/sync": {
            "get": {
                "operationId": "syncPosters",
                "parameters": [
                    {
                        "name": "title",
                        "required": false,
                        "in": "query",
                        "description": "Filter by program title",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sync triggered"
                    }
                },
                "summary": "Sync poster images from SearXNG for programs without poster",
                "tags": [
                    "SearXNG"
                ]
            }
        },
        "/api/xml-tv/run": {
            "get": {
                "description": "Require x-forwarded-for header with valid value to start cron",
                "operationId": "startJob",
                "parameters": [
                    {
                        "name": "x-forwarded-for",
                        "in": "header",
                        "description": "Header to prevent running cron",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": ""
                    }
                },
                "summary": "Start cront to download new xml and update database",
                "tags": [
                    "xml-tv"
                ]
            }
        }
    },
    "info": {
        "title": "TV FR API",
        "description": "API for French TV channels and programs based on racacax/XML-TV-Fr",
        "version": "1.0",
        "contact": {}
    },
    "tags": [],
    "servers": [
        {
            "url": "https://tv-api.miceli.click"
        }
    ],
    "components": {
        "schemas": {
            "Channel": {
                "type": "object",
                "properties": {}
            }
        }
    }
}
